{
  "name": "penhoras-server-app",
  "version": "0.1.0",
  "description": "Aplicativo desktop para gerenciar o servidor de automações Penhoras",
  "repository": {
    "type": "git",
    "url": "https://github.com/EstevaoTerci/penhoras-server.git"
  },
  "bugs": {
    "url": "https://github.com/EstevaoTerci/penhoras-server/issues"
  },
  "homepage": "https://github.com/EstevaoTerci/penhoras-server#readme",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:prod": "cross-env NODE_ENV=production electron .",
    "start:online": "electron .",
    "start:emulators": "cross-env USE_FIRESTORE_EMULATOR=true electron .",
    "dev": "nodemon",
    "dev:prod": "cross-env NODE_ENV=production nodemon",
    "dev:online": "nodemon",
    "dev:emulators": "cross-env USE_FIRESTORE_EMULATOR=true nodemon",
    "download-node": "node download-node.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "dist": "electron-builder --win --publish never",
    "prebuild": "node download-node.js"
  },
  "author": "Estêvão Terci da Silva",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.10"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "electron-log": "^5.2.2",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.penhoras.server",
    "productName": "PenhorasServer",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "**/*",
      "!**/*.ts",
      "!*.map"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../server/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../server/package.json",
        "to": "server/package.json"
      },
      {
        "from": "../server/.env.production",
        "to": "server/.env.production"
      },
      {
        "from": "../server/.env.local",
        "to": "server/.env.local"
      },
      {
        "from": "../server/private",
        "to": "server/private",
        "filter": [
          "*.json"
        ]
      },
      {
        "from": "node-portable",
        "to": "node",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Penhoras Server",
      "uninstallDisplayName": "Penhoras Server",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true
    },
    "publish": {
      "provider": "github",
      "owner": "EstevaoTerci",
      "repo": "penhoras-server"
    }
  }
}
